{
  "installCommand": "pnpm install",
  "buildCommand": "turbo build",
  "outputDirectory": "apps/web/.next",
  "functions": {
    "apps/api/main.py": {
      "runtime": "python3.12",
      "maxDuration": 300
    }
  },
  "rewrites": [{ "source": "/api/:path*", "destination": "/apps/api/main.py" }],
  "crons": [
    {
      "path": "/api/scan/trigger?source=reddit",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/agents/cron",
      "schedule": "*/30 * * * *"
    }
  ]
}
