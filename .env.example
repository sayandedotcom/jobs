# Database (PostgreSQL with pgvector)
DATABASE_URL="postgresql://user:password@localhost:5432/jobs"

# Better Auth
BETTER_AUTH_SECRET="generate-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Python API (.env in apps/api/)
REDDIT_CLIENT_ID="your-reddit-app-client-id"
REDDIT_CLIENT_SECRET="your-reddit-app-client-secret"
REDDIT_USER_AGENT="jobs-aggregator/0.1.0"
GEMINI_API_KEY="your-gemini-api-key"
WWR_API_KEY="your-weworkremotely-bearer-token"
X_BEARER_TOKEN="your-x-api-v2-bearer-token"
CRON_SECRET="a-random-secret-to-secure-cron-endpoint"
PYTHON_API_URL="http://localhost:8000"

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:8000"
